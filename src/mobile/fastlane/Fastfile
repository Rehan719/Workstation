# ARTICLE 402: Mobile App Beta Deployment Automation
default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    increment_build_number(xcodeproj: "ios/julesai.xcodeproj")
    build_app(scheme: "julesai")
    upload_to_testflight
  end
end

platform :android do
  desc "Submit a new Beta Build to Play Store"
  lane :beta do
    gradle(task: "bundle", build_type: "Release")
    upload_to_play_store(track: "beta")
  end
end
